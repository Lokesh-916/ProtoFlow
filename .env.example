# ProtoFlow Environment Variables — EXAMPLE
# Copy this file to .env and fill in your real values.
# ─────────────────────────────────────────────────────────────────────────────

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

APP_ENV=development
LOG_LEVEL=debug

MAX_REPAIR_LOOPS=3
HITL_TIMEOUT_SECONDS=300
SESSION_STORE=memory

DEFAULT_TEMPERATURE_SCHEMA=0.2
DEFAULT_TEMPERATURE_INTENT=0.4
DEFAULT_TEMPERATURE_VALIDATOR=0.1
DEFAULT_TEMPERATURE_LOGGER=0.3

HOST=0.0.0.0
PORT=8000
